<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if page.title and page.title != 'about' %}{{ page.title }} | {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ page.description | default: site.description | escape }}">
    <link rel="stylesheet" href="{{ '/assets/css/custom.css' | relative_url }}">
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <div>
          <a class="site-title" href="{{ '/' | relative_url }}">{{ site.title }}</a>
          {% if site.subtitle %}<div class="site-subtitle">{{ site.subtitle }}</div>{% endif %}
        </div>
        <nav class="site-nav">
          {% assign nav_pages = site.pages | where_exp: 'item', 'item.nav == true' | sort: 'nav_order' %}
          {% for p in nav_pages %}
            <a href="{{ p.url | relative_url }}">{{ p.title | capitalize }}</a>
          {% endfor %}
        </nav>
      </div>
    </header>

    <main class="container main-content">
      {{ content }}
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>{{ site.footer_text }}</p>
      </div>
    </footer>
  </body>
</html>
