---
layout: default
---
<section class="hero">
  <div class="hero-main">
    <p class="eyebrow">{{ page.subtitle }}</p>
    <h1>{{ site.title }}</h1>
    {% if site.subtitle %}<p class="hero-subtitle">{{ site.subtitle }}</p>{% endif %}
    <div class="hero-content">
      {{ content }}
    </div>
  </div>
  <aside class="hero-side">
    <div class="card">
      <h2>Links</h2>
      <ul class="link-list">
        <li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        <li><a href="https://github.com/{{ site.author.github }}">GitHub</a></li>
        <li><a href="https://linkedin.com/in/{{ site.author.linkedin }}">LinkedIn</a></li>
        <li><a href="{{ '/resume/' | relative_url }}">Resume</a></li>
      </ul>
    </div>
  </aside>
</section>
